callback[Event.Area](1, 1, 27, 10, 0, "") {
    if (ev::TurnGet() > 10) {
        v0 = ev::ForceUnitGetFirst(1);
        while (v0) {
            ev::AiSetSequence(v0, 3, "AI_MV_WeakEnemy", "");
            ev::AiSetMoveLimit(v0, 0, -1, -1, -1, -1);
            v0 = ev::ForceUnitGetNext(v0);
        }
        ev::FlagSet("思考近敵");
        goto l3;
    }
    ev::FlagClr("思考近敵");
    label l3;
}

