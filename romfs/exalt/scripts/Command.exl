    }
}

def ev::MapEventBeginForOpening(v0) {
    ev::MapEventDirectBeginForOpening(ev::ChapterGetName(), v0);
}

def ev::MapEventDirectBeginForOpening(v0, v1) {
    if (v1 != 0) {
        ev::ChapterSetTrickDragon(v1);
    }
    ev::TerrainLoad(v0);
    ev::PersonLoad(ev::ChapterGetName());
    ev::DisposLoad(ev::ChapterGetName());
    ev::TerrainDrawBegin();
    ev::EffectHideTrick();
    ev::ChapterSetHideHpGauge(1);
    ev::BeginEventCamera();
}

def ev::MapEventEndForOpening() {
    ev::EnvSEOff(250);
    ev::FadeOut(3, 0, 250);
    ev::FadeWait();
    ev::ChapterSetHideHpGauge(0);
    ev::EffectShowTrick();
    ev::TerrainDrawEnd();
    ev::DisposFree();
    ev::TerrainFree();
    ev::PersonFree(ev::ChapterGetName());
    ev::EndEventCamera();
}

def ev::MapEventBeginForComplete() {
    ev::ForceUnitDelete(0);
    ev::ForceUnitDelete(1);
    ev::ForceUnitDelete(2);
    ev::EffectHideTrick();
    ev::ChapterSetHideHpGauge(1);
    ev::BeginEventCamera();
}

def ev::MapEventEndForComplete() {
    ev::EnvSEOff(250);
    ev::FadeOut(3, 0, 250);
    ev::FadeWait();
    ev::ChapterSetHideHpGauge(0);
    ev::EffectShowTrick();
    ev::EndEventCamera();
}

def ev::CutSceneGameEventBegin(v0, v1) {
    if (ev::FlagGet(v1)) {
        return 0;
    }
    if (v0) {
        ev::SkipDisable();
        goto l2;
    }
    ev::EnvSEOn(250);
    ev::FadeIn(3, 0, 250);
    ev::FadeWait();
    label l2;
    ev::FlagSet(v1);
    return 1;
}

def ev::CutSceneGameEventEnd(v0) {
    if (v0) {
        ev::SkipEnable();
        goto l1;
    }
    ev::EnvSEOff(250);
    ev::FadeOut(3, 0, 250);
    ev::FadeWait();
    label l1;
}

def ev::Clamp(v0, v1, v2) {
    if (v0 < v1) {
        return v1;
    }
    if (v0 > v2) {
        return v2;
    }
    return v0;
}

def ev::BeginEventCamera() {
    ev::BandOpen();
    ev::CameraSetAngle(-40);
    ev::CameraSetDistanceFromNear();
}

def ev::EndEventCamera() {
    ev::BandClose();
    ev::CameraSetRoll(0);
    ev::CameraSetAngleFromConfig();
    ev::CameraSetDistanceFromConfig();
}

def ev::FadeOutEventCamera() {
    ev::EnvSEOff(250);
    ev::FadeOut(3, 0, 250);
    ev::FadeWait();
    ev::EndEventCamera();
}

callback[Event.GlobalLoad]() {}

callback[Event.ScriptLoad]() {
    ev::FlagEntry("Shadowgift");
    ev::FlagEntry("RallySpectrum");
    ev::FlagEntry("Resolve");
}

callback[Event.Turn](1, 1, 0) {
    v0 = ev::ForceUnitGetFirst(0);
    while (v0) {
        v1 = ev::ForceUnitGetNext(v0);
        if (ev::UnitIsEquipSkill(v0, SHADOWGIFT)) {
            ev::FlagSet("Shadowgift");
            v2 = ev::UnitGetByPID("PID_B024_アサマ");
            if (v2) {
                if (!ev::UnitIsEquipSkill(v2, STAFF_SAVANT)) {
                    ev::UnitAddEquipSkill(v2, STAFF_SAVANT);
                }
            }
            break;
        }
        if ((ev::UnitIsJID(v0, WITCH_F) || ev::UnitIsJID(v0, "JID_魔女男")) && ev::UnitGetLevel(v0) < 5) {
            ev::FlagSet("Shadowgift");
            break;
        }
        v0 = v1;
    }
}

callback[Event.Turn](2, -1, 0) {
    if (ev::FlagGet("Shadowgift")) {
        v0 = ev::ForceUnitGetFirst(0);
        while (v0) {
            v1 = ev::ForceUnitGetNext(v0);
            if (ev::UnitIsEquipSkill(v0, SHADOWGIFT)) {
                ev::UnitClrEnhance(v0, 7);
                ev::UnitClrEnhance(v0, 6);
                ev::UnitClrEnhance(v0, 5);
                v2 = ev::UnitGetWeakness(v0, 2);
                if (v2 > 1) {
                    v2 = (v2 * -1) / 2;
                    ev::UnitAddWeakness(v0, 2, v2);
                }
                v2 = ev::UnitGetWeakness(v0, 1);
                if (v2 > 1) {
                    v2 = (v2 * -1) / 2;
                    ev::UnitAddWeakness(v0, 1, v2);
                }
            }
            v0 = v1;
        }
    }
}

callback[Event.Area](-1, -1, -1, -1, -1, "") {
    if (ev::FlagGet("Shadowgift")) {
        v0 = ev::ForceUnitGetFirst(0);
        while (v0) {
            v1 = ev::ForceUnitGetNext(v0);
            if (ev::UnitIsEquipSkill(v0, SHADOWGIFT) && ev::UnitItemIsExist(v0, NOSFERATU)) {
                ev::UnitClrEnhance(v0, 7);
                ev::UnitClrEnhance(v0, 6);
                ev::UnitClrEnhance(v0, 5);
                v2 = ev::UnitGetWeakness(v0, 2);
                if (v2 > 1) {
                    v2 = v2 * -1;
                    ev::UnitAddWeakness(v0, 2, v2);
                }
                v2 = ev::UnitGetWeakness(v0, 1);
                if (v2 > 1) {
                    v2 = v2 * -1;
                    ev::UnitAddWeakness(v0, 1, v2);
                }
            }
            v0 = v1;
        }
    }
}

callback[Event.Turn](1, 1, 0) {
    v0 = ev::ForceUnitGetFirst(0);
    while (v0) {
        v1 = ev::ForceUnitGetNext(v0);
        if (ev::UnitIsEquipSkill(v0, RIFLED_BARREL)) {
            ev::FlagSet("RallySpectrum");
            break;
        }
        if (((ev::UnitIsJID(v0, GRANDMASTER_M) || ev::UnitIsJID(v0, "JID_神軍師女")) && ev::UnitGetLevel(v0) > 10) && ev::UnitGetLevel(v0) < 15) {
            ev::FlagSet("RallySpectrum");
            break;
        }
        v0 = v1;
    }
}

callback[Event.TurnAfter](-1, -1, 0) {
    if (ev::FlagGet("RallySpectrum")) {
        v0 = ev::ForceUnitGetFirst(0);
        while (v0) {
            v1 = ev::ForceUnitGetNext(v0);
            if (ev::UnitIsEquipSkill(v0, RIFLED_BARREL) && !ev::UnitIsDoubleChild(v0)) {
                v2 = ev::UnitGetX(v0);
                v3 = ev::UnitGetY(v0);
                v4 = ev::ForceUnitGetFirst(0);
                while (v4) {
                    v5 = ev::UnitGetX(v4);
                    v6 = ev::UnitGetY(v4);
                    if (v2 - v5 == 1 || v5 - v2 == 1) {
                        if (v3 == v6) {
                            ev::UnitSetEnhance(v4, 31);
                        }
                    }
                    if (v6 - v3 == 1 || v3 - v6 == 1) {
                        if (v2 == v5) {
                            ev::UnitSetEnhance(v4, 31);
                        }
                    }
                    v7 = ev::ForceUnitGetNext(v4);
                    v4 = v7;
                }
            }
            v0 = v1;
        }
    }
}

callback[Event.Turn](1, 1, 0) {
    v0 = ev::ForceUnitGetFirst(0);
    while (v0) {
        v1 = ev::ForceUnitGetNext(v0);
        if (ev::UnitIsEquipSkill(v0, SUREFOOTED)) {
