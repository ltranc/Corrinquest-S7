def ev::MoviePlay(v0) {
    if (!ev::SkipIsActive()) {
        v1 = ev::SkipIsDisable();
        if (!v1) {
            ev::SkipDisable();
        }
        ev::MapSuspend();
        ev::MoviePlayImpl(v0, 1);
        ev::MapResume();
        if (!v1) {
            ev::SkipEnable();
        }
        if (ev::MovieIsSkipped()) {
            ev::SkipTrigger();
        }
    }
}

def ev::MoviePlayNoBind(v0) {
    if (!ev::SkipIsActive()) {
        ev::MoviePlayNoBindWithEscapeSkip(v0);
