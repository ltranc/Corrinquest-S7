callback[Event.Reinforce](12, 12, 1) {
    ev::Dispos("Boss3", 8);
    ev::DisposWait();
    v0 = ev::UnitGetByPID("PID_X021_マーシナリー騎士");
    if (v0) {
        ev::UnitSetMovePower(v0, 7);
    }
    v0 = ev::ForceUnitGetFirst(2);
    while(v0) {
        ev::AiSetSequence(v0, 3, "AI_MV_Force", "0");
        v0 = ev::ForceUnitGetNext(v0);
    }
}

