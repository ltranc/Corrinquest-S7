callback[Event.Area](-1, -1, -1, -1, -1) {
    v0 = ev::UnitGetByPID("PID_X021_ボス6");
    if (v0) {
        if (ev::UnitGetHP(v0) * 2 <= ev::UnitGetMHP(v0)) {
            ev::UnitSetEnhance(v0, 16);
            ev::UnitSetEnhance(v0, 17);
            ev::UnitSetEnhance(v0, 18);
            ev::UnitSetEnhance(v0, 19);
            goto l0;
        }
        ev::UnitClrEnhance(v0, 16);
        ev::UnitClrEnhance(v0, 17);
        ev::UnitClrEnhance(v0, 18);
        ev::UnitClrEnhance(v0, 19);
    }
    label l0;
}

callback[Event.Talk](LASLOW, 0, SOLEIL, 2, 1, "ソレイユ味方") {
    ev::BGMStop(1000);
    ev::CameraSetAngle(-40);
    ev::CameraSetDistanceFromNear();
    ev::Talk("MID_X021_TK1");
    v0 = ev::UnitGetByPID(SOLEIL);
    ev::UnitTransferByIndex(v0, 0);
    ev::FlagSet("ソレイユ味方");
    ev::CameraSetAngleFromConfig();
    ev::CameraSetDistanceFromConfig();
    ev::BGMStop(1000);
    ev::TimeWait(500);
}

callback[Event.BattleTalk]("PID_X021_ボス", 1, "", -1, 1, "戦闘会話") {
    ev::Talk("MID_X021_BT1");
    ev::FlagSet("戦闘会話");
}

callback[Event.Die]("PID_X021_ボス", 1, "", -1) {
    ev::Talk("MID_X021_BOSS_DIE1");
}

callback[Event.Die](SOLEIL, -1, "", -1) {
    ev::Talk("MID_X021_DIE_ソレイユ");
}

callback[Event.MapComplete]() {
    ev::EnvSEOff(250);
    ev::FadeOut(3, 0, 250);
    ev::FadeWait();
    ev::VariableSet("緑軍生存人数", ev::ForceUnitGetCount(2));
}

def ev::X021_アイテム入手(v0) {
    if (ev::CutSceneGameEventBegin(v0, "カットシーン")) {
        v1 = ev::VariableGet("緑軍生存人数");
        if (v1 >= 4) {
            ev::ItemGain(0, DRACOSHIELD);
            ev::ItemGain(0, PHYSIC);
            ev::ItemGain(0, GOLD_BAR);
            goto l2;
        }
        if (v1 >= 3) {
            ev::ItemGain(0, PHYSIC);
            ev::ItemGain(0, GOLD_BAR);
            goto l2;
        }
        if (v1 >= 2) {
            ev::ItemGain(0, GOLD_BAR);
            goto l2;
        }
        if (v1 >= 1) {
            ev::ItemGain(0, MEND);
            goto l2;
        }
        ev::ItemGain(0, VULNERARY);
        label l2;
        ev::ItemGain(0, IRON_SWORD);
        ev::ItemGain(0, VULNERARY);
        ev::CutSceneGameEventEnd(v0);
    }
}

callback[Event.MapEnding]() {
    ev::CutScene("X021_ED1");
    ev::X021_アイテム入手(0);
}

