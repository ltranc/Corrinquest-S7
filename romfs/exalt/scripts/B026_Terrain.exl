include std:fe14:prelude;

def anonfn0(v0) {
    v1 = ev::ForceUnitGetFirst(1);
    while (v1) {
        if (ev::AiGetBand(v1) == v0) {
            ev::AiSetSequence(v1, 0, "AI_AC_Everytime", "");
        }
        v1 = ev::ForceUnitGetNext(v1);
    }
}

def anonfn1(v0) {
    v1 = ev::ForceUnitGetFirst(1);
    while (v1) {
        if (ev::AiGetBand(v1) == v0) {
            ev::AiSetSequence(v1, 0, "AI_AC_Everytime", "");
            ev::AiSetSequence(v1, 3, "AI_MV_WeakEnemy", "");
        }
        v1 = ev::ForceUnitGetNext(v1);
    }
}

def anonfn2(v0) {
    v1 = ev::ForceUnitGetFirst(1);
    while (v1) {
        if (ev::AiGetBand(v1) == v0) {
            ev::AiSetSequence(v1, 0, "AI_AC_AttackRange", "");
        }
        v1 = ev::ForceUnitGetNext(v1);
    }
}

def anonfn3(v0) {
    v1 = ev::ForceUnitGetFirst(1);
    while (v1) {
        if (ev::AiGetBand(v1) == v0) {
            ev::AiClrFlag(v1, 256);
        }
        v1 = ev::ForceUnitGetNext(v1);
    }
}

callback[Event.Poke](13, 19, 1, 1, 3, 0, 0, "") {}

callback[Event.Poke](13, 10, 2, 1, 9, 50, 0, "") {
    if (ev::TrickGetHp(ev::ArgsGetInt(0), ev::ArgsGetInt(1), ev::ArgsGetInt(4)) > 0) {
        ev::TrickSet(ev::ArgsGetInt(0), ev::ArgsGetInt(1), ev::ArgsGetInt(4), 2, 0);
        goto l1;
    }
    ev::TrickSet(ev::ArgsGetInt(0), ev::ArgsGetInt(1), ev::ArgsGetInt(4), 4, 0);
    label l1;
    anonfn0(1);
}

