callback[Event.Poke](7, 25, 1, 2, 9, 50, 0, "") {
    if (ev::TrickGetHp(ev::ArgsGetInt(0), ev::ArgsGetInt(1), ev::ArgsGetInt(4)) > 0) {
        ev::TrickSet(ev::ArgsGetInt(0), ev::ArgsGetInt(1), ev::ArgsGetInt(4), 2, 0);
        goto l1;
    }
    ev::TrickSet(ev::ArgsGetInt(0), ev::ArgsGetInt(1), ev::ArgsGetInt(4), 4, 0);
    label l1;
    anonfn0(8);
    anonfn2(9);
    if (ev::FlagGet("増援条件1")) {
        ev::TrickSet(22, 19, 9, 2, 0);
    }
    ev::FlagSet("増援条件4");
    v0 = ev::ForceUnitGetFirst(1);
    while(v0) {
        if(ev::AiGetBand(v0) == 9) {
           ev::AiSetSequence(v0, 3, "AI_MV_WeakEnemy", "");
        }
        v0 = ev::ForceUnitGetNext(v0);
    }
}

