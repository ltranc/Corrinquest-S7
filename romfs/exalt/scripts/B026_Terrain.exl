    ev::FlagSet("増援条件2");
}

callback[Event.Poke](3, 23, 2, 1, 9, 50, 0, "") {
    if (ev::TrickGetHp(ev::ArgsGetInt(0), ev::ArgsGetInt(1), ev::ArgsGetInt(4)) > 0) {
        ev::TrickSet(ev::ArgsGetInt(0), ev::ArgsGetInt(1), ev::ArgsGetInt(4), 2, 0);
        goto l1;
    }
    ev::TrickSet(ev::ArgsGetInt(0), ev::ArgsGetInt(1), ev::ArgsGetInt(4), 4, 0);
    label l1;
    if (ev::FlagGet("増援条件2")) {
        anonfn0(3);
        anonfn0(4);
        anonfn0(5);
        anonfn3(10);
    }
}

