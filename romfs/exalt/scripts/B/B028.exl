callback[Event.Reinforce](11, -1, 1) {
    v0 = ev::TurnGet();
    v0 -= 4;
    v1 = [
        "Reinforce01", "Reinforce02", "Reinforce03", "Reinforce04", 
        "Reinforce05", "Reinforce06", "Reinforce11", "Reinforce12", 
        "Reinforce13", "Reinforce14", "Reinforce15", "Reinforce16", 
        "Reinforce21", "Reinforce22", "Reinforce23", "Reinforce24", 
        "Reinforce25", "Reinforce26", 
    ];
    v19 = ((v0 / 4) % 3) * 6;
    match (v0 % 4) {
        0 -> {
            ev::Dispos(v1[v19 + 0], 8);
            ev::DisposWait();
            ev::Dispos(v1[v19 + 1], 8);
            ev::DisposWait();
        }
        1 -> {
            ev::Dispos(v1[v19 + 2], 8);
            ev::DisposWait();
            ev::Dispos(v1[v19 + 3], 8);
            ev::DisposWait();
        }
        2 -> {
            ev::Dispos(v1[v19 + 4], 8);
            ev::DisposWait();
            ev::Dispos(v1[v19 + 5], 8);
            ev::DisposWait();
        }
    }
    if (v0 >= 4) {
        v20 = [
            "Reinforce31", "Reinforce32", "Reinforce33", "Reinforce34", 
            "Reinforce35", "Reinforce36", "Reinforce41", "Reinforce42", 
            "Reinforce43", "Reinforce44", "Reinforce45", "Reinforce46", 
            "Reinforce51", "Reinforce52", "Reinforce53", "Reinforce54", 
            "Reinforce55", "Reinforce56", "Reinforce61", "Reinforce62", 
            "Reinforce63", "Reinforce64", "Reinforce65", "Reinforce66", 
        ];
        v44 = ((v0 / 4) % 4) * 6;
        v45 = (v0 / 4) % 6;
        match (v45) {
            0 -> {
                if (v0 % 4 == 1) {
                    ev::Dispos(v20[v44 + 0], 8);
                    ev::DisposWait();
                }
            }
            1 -> {
                if (v0 % 4 == 3) {
                    ev::Dispos(v20[v44 + 5], 8);
                    ev::DisposWait();
                }
            }
            2 -> {
                if (v0 % 4 == 2) {
                    ev::Dispos(v20[v44 + 2], 8);
                    ev::DisposWait();
                }
            }
            3 -> {
                if (v0 % 4 == 1) {
                    ev::Dispos(v20[v44 + 1], 8);
                    ev::DisposWait();
                }
            }
            4 -> {
                if (v0 % 4 == 3) {
                    ev::Dispos(v20[v44 + 4], 8);
                    ev::DisposWait();
                }
            }
            5 -> {
                if (v0 % 4 == 2) {
                    ev::Dispos(v20[v44 + 3], 8);
                    ev::DisposWait();
                }
            }
        }
    }
}

