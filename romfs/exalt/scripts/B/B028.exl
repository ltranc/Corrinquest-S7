    ev::TimeWait(500);
    v0 = ev::UnitGetPlayer();
    ev::CameraSetPositionByUnit(v0);
    ev::CameraWait();
    ev::CameraSetAngle(-40);
    ev::CameraSetDistanceFromNear();
    ev::Talk("MID_B028_EV6_1");
    ev::CameraSetPosition(15, 29);
    ev::CameraWait();
    ev::TimeWait(500);
    ev::Talk("MID_B028_EV6_2");
    ev::CameraSetAngleFromConfig();
    ev::CameraSetDistanceFromConfig();
    ev::TimeWait(500);
    ev::CameraSetPositionByUnit(v0);
    ev::CameraWait();
}

callback[Event.TurnAfter](-1, -1, 1) {
    v0 = 3;
    if (ev::DifficultyGet() >= 2) {
        v0 = 2;
    }
    v1 = ev::ForceUnitGetFirst(1);
    while (v1) {
        v2 = ev::ForceUnitGetNext(v1);
        if (ev::UnitIsEquipSkill(v1, SELF_DESTRUCT) && ev::UnitGetHP(v1) <= ev::UnitGetMHP(v1) / 2) {
            anonfn9(v1);
        }
        v1 = v2;
    }
    if (ev::TurnGet() % v0 == v0 - 1) {
        v3 = ev::UnitGetByPID("PID_B028_ボス");
        if (v3) {
            v4 = ev::UnitGetX(v3);
            v5 = ev::UnitGetY(v3);
            ev::CameraSetPosition(v4, v5);
            ev::CameraWait();
            v6 = ev::VariableGet("チャージHandle");
            if (v6) {
                ev::EffectFadeOut(v6, 100);
            }
            ev::SEPlay3D("SE_BTL_EFF_ALLATTACKCHARGE", v4, v5);
            v6 = ev::EffectPlayEternal3D("Fld_B028_AllAttack_Charge", v4, v5);
            ev::VariableSet("チャージHandle", v6);
            ev::TimeWait(1000);
        }
    }
    if (ev::TurnGet() % v0 == 0) {
        v7 = ev::UnitGetByPID("PID_B028_ボス");
        if (v7) {
            v8 = [
                15, 23, 14, 23, 
                16, 23, 13, 18, 
                17, 18, 
            ];
            v18 = ev::UnitGetX(v7);
            v19 = ev::UnitGetY(v7);
            ev::CameraSetPosition(v18, v19);
            ev::CameraWait();
            v20 = ev::VariableGet("チャージHandle");
            if (v20) {
                ev::EffectFadeOut(v20, 100);
                ev::VariableSet("チャージHandle", 0);
            }
            ev::EffectPlay3D("Fld_B028_AllAttack", v18, v19);
            ev::EffectWait();
            v21 = 0;
            v22 = ev::ForceUnitGetFirst(0);
            while (v22) {
                v23 = ev::ForceUnitGetNext(v22);
                if (!ev::UnitIsDoubleChild(v22)) {
                    v24 = ev::UnitGetX(v22);
                    v25 = ev::UnitGetY(v22);
                    v26 = 1;
                    if (v24 == 13 || v24 == 17) {
                        if (v25 <= 18 && ev::TrickTst(v24, 18, 12, 1)) {
                            v26 = 0;
                        }
                        goto l15;
                    }
                    if ((v24 == 14 || v24 == 15) || v24 == 16) {
                        if (v25 <= 23 && ev::TrickTst(v24, 23, 12, 1)) {
                            v26 = 0;
                        }
                    }
                    label l15;
                    if (v26) {
                        ev::CameraSetPosition(v24, v25);
                        ev::CameraWait();
                        v21 = 1;
                        break;
                    }
                }
                v22 = v23;
            }
            if (!v21) {
                for (v27 = 0; v27 < 5; v27++) {
                    if (ev::TrickTst(v8[v27 * 2], v8[v27 * 2 + 1], 12, 1)) {
                        ev::CameraSetPosition(v8[v27 * 2], v8[v27 * 2 + 1]);
                        ev::CameraWait();
                        v21 = 1;
                        break;
                    }
                }
            }
            v28 = ev::ForceUnitGetFirst(0);
            while (v28) {
                v29 = ev::ForceUnitGetNext(v28);
                if (!ev::UnitIsDoubleChild(v28)) {
                    v30 = ev::UnitGetX(v28);
                    v31 = ev::UnitGetY(v28);
                    v32 = 1;
                    if (v30 == 13 || v30 == 17) {
                        if (v31 <= 18 && ev::TrickTst(v30, 18, 12, 1)) {
                            v32 = 0;
                        }
                        goto l30;
                    }
                    if ((v30 == 14 || v30 == 15) || v30 == 16) {
                        if (v31 <= 23 && ev::TrickTst(v30, 23, 12, 1)) {
                            v32 = 0;
                        }
                    }
                    label l30;
                    if (v32) {
                        ev::UnitHpDamage(v28, ev::UnitGetMHP(v28) / 2);
                    }
                }
                v28 = v29;
            }
            for (v33 = 0; v33 < 5; v33++) {
                if (ev::TrickTst(v8[v33 * 2], v8[v33 * 2 + 1], 12, 1)) {
                    ev::TrickSet(v8[v33 * 2], v8[v33 * 2 + 1], 12, 4, 1);
