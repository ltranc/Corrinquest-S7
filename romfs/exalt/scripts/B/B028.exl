callback[Event.TurnAfter](1, 1, 1) {
}

callback[Event.TurnAfter](1, 4, 1) {
    if (ev::FlagGet("SidesPairUp") && !ev::FlagGet("Paired")) {
        ev::SkipDisable();
        anonfn30(3, 23, 3, 22);
        anonfn30(4, 23, 4, 22);
        anonfn30(25, 23, 26, 23);
        anonfn30(25, 24, 26, 24);
        ev::SkipEnable();
        ev::FlagSet("Paired");
    }
    if (ev::TurnGet() == 4 && !ev::FlagGet("Paired")) {
        ev::SkipDisable();
        anonfn30(3, 23, 3, 22);
        anonfn30(4, 23, 4, 22);
        anonfn30(26, 23, 27, 23);
        anonfn30(26, 24, 27, 24);
        ev::SkipEnable();
        ev::FlagSet("Paired");
    }
}

