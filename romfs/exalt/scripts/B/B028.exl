def ev::B028_Enthusiasm() {
    v0 = ev::UnitGetPlayer();
    v1 = ev::ForceUnitGetFirst(3);
    v2 = 0;
    while (v1) {
        v3 = ev::ForceUnitGetNext(v1);
        if (v1 != v0) {
            anonfn5(v1);
            v2++;
            if (v2 >= 15) {
                break;
            }
        }
        v1 = v3;
    }
}

