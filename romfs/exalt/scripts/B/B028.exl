callback[Event.ScriptLoad]() {
    ev::FlagEntry("戦闘会話");
    ev::FlagEntry("戦闘会話_プレイヤー");
    ev::FlagEntry("SidesPairUp");
    ev::FlagEntry("Paired");
    ev::VariableEntry("チャージHandle", 0);
}

callback[Event.MapLoad]() {
