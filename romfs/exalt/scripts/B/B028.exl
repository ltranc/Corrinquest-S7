            v2 = ev::UnitGetX(v1);
            v3 = ev::UnitGetY(v1);
            v0 = ev::EffectPlayEternal3D("Fld_B028_AllAttack_Charge", v2, v3);
            ev::VariableSet("チャージHandle", v0);
            goto l0;
        }
        ev::VariableSet("チャージHandle", 0);
    }
    label l0;
}

def anonfn9(v0) {
    v1 = ev::UnitGetX(v0);
    v2 = ev::UnitGetY(v0);
    ev::CameraSetPosition(v1, v2);
    ev::CameraWait();
    v3 = [
        0, -2, -1, -1, 
        0, -1, 1, -1, 
        -2, 0, -1, 0, 
        1, 0, 2, 0, 
        -1, 1, 0, 1, 
        1, 1, 0, 2, 
    ];
    for (v27 = 0; v27 < 12; v27++) {
        v28 = v1 + v3[v27 * 2];
        v29 = v2 + v3[v27 * 2 + 1];
        if (ev::TerrainIsOutOfPlayArea(v28, v29)) {
            continue;
        }
        v30 = ev::UnitGetByPosition(v28, v29);
        if (v30 && ev::UnitGetForce(v30) == 0) {
            ev::UnitHpDamage(v30, ev::UnitGetMHP(v30) / 2);
        }
        if (ev::TrickTryTst(v28, v29, 12, 1)) {
            ev::TrickSet(v28, v29, 12, 4, 1);
        }
    }
    ev::UnitMoveAlphaDeadOut(v0);
    yield;
    ev::UnitHpEffectWait();
    ev::UnitMoveWait();
    ev::UnitExpulsionByIndex(v0);
}

callback[Event.Turn](1, 1, 0) {
