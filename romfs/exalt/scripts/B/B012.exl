callback[Event.GameOver]() {
    if (ev::ChapterGetWinLoseResult() == 5) {
        ev::BGMStop(2000);
        ev::Talk("MID_B012_TURNOVER");
        goto l1;
    }
    ev::GameOverCommon();
    label l1;
}

callback[Event.MapComplete]() {
    ev::BeginEventCamera();
    ev::Talk("MID_B012_ED_リョウマ");
    ev::FadeOutEventCamera();
}

callback[Event.MapEnding]() {
    ev::CutScene("B012_ED");
    ev::CutScene("B012_ED2");
}

