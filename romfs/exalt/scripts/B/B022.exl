}

callback[Event.Turn](1, 1, 1) {}

callback[Event.Turn](-1, -1, 1) {
    v0 = ev::UnitGetByPID("PID_B022_サクラ");
    if (v0) {
        ev::UnitItemPutOff(v0, "IID_HAMAYA");
        ev::ItemGainSilent(v0, "IID_HAMAYA2");
        ev::UnitItemEquip(v0);
        ev::UnitItemClearDrop(v0);
        ev::UnitItemPutOff(v0, SPIRIT_DUST);
        ev::ItemGainSilent(v0, SPIRIT_DUST);
    }
}

callback[Event.Turn](2, -1, 0) {
    v0 = ev::UnitGetByPID("PID_B022_サクラ");
    if (v0) {
        ev::UnitItemPutOff(v0, "IID_HAMAYA2");
