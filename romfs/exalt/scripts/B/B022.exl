callback[Event.Turn](-1, -1, 0) {
    if (ev::FlagGet("敵増援条件竜脈")) {
        v0 = [
            4, 14, 14, 13, 
            5, 7, 17, 9, 
            8, 5, 17, 3, 
        ];
        v12 = [
            19, 16, 3, 13, 
            22, 13, 6, 6, 
            20, 7, 10, 4, 
        ];
        v24 = 0;
        for (v25 = 0; v25 < 6; v25++) {
            if (ev::TrickTst(v0[v25 * 2], v0[v25 * 2 + 1], 12, 2)) {
                v24 = 1;
                break;
            }
        }
        if (v24) {
            v26 = 13;
            v27 = 5;
            if (ev::TrickTst(v26, v27, 11, 1)) {
                v28 = ev::UnitGetByPID("PID_B022_サクラ");
                if (v28) {
                    ev::CameraSetPosition(v26, v27);
                    ev::CameraWait();
                    ev::TrickSetForDragon(v26, v27, 2, 1, "4, 14, 14, 13, 5, 7, 17, 9, 8, 5, 17, 3");
                    for (v29 = 0; v29 < 6; v29++) {
                        if (ev::TrickTst(v12[v29 * 2], v12[v29 * 2 + 1], 11, 2)) {
                            ev::TrickSet(v12[v29 * 2], v12[v29 * 2 + 1], 11, 1, 0);
                        }
                    }
                }
            }
        }
    }
}

callback[Event.TurnAfter](2, 2, 1) {
    v0 = ev::UnitGetByPosition(13, 2);
    v1 = ev::UnitGetByPID("PID_B022_ボス");
    if (v0) {
        ev::CameraSetPositionByUnit(v1);
        ev::CameraWait();
        ev::TimeWait(250);
        ev::UnitDoubleOn(v1, v0);
        ev::TimeWait(250);
    }
}

callback[Event.Reinforce](1, 1, 1) {
    v0 = ev::UnitGetByPID("PID_B022_ボス");
    if (v0) {
        ev::CameraSetPositionByUnit(v0);
        ev::CameraWait();
        ev::TimeWait(250);
        v1 = ev::UnitCreateClone(v0, 13, 2);
        ev::UnitSetStatus(v0, 1, 0);
        ev::UnitSetStatus(v1, 1, 0);
        ev::TimeWait(250);
    }
    ev::Dispos("Reinforce00", 8);
    ev::DisposWait();
    ev::Talk("MID_B022_EV2");
    ev::TutorialDialogMustShow("MID_B022_DIALOG2");
}

def ev::Defeat() {
    if (ev::FlagGet("SeizeAllowed")) {
        return 0;
    }
    if (ev::UnitGetByPID("PID_B022_カザハナ")) {
        return 0;
    }
    if (ev::UnitGetByPID("PID_B022_ツバキ")) {
        return 0;
    }
    return 1;
}

callback[Event.Area](-1, -1, -1, -1, -1, "Defeat") {
    ev::TrickSet(13, 1, 3, 1, 0);
    ev::FlagSet("SeizeAllowed");
}

callback[Event.Reinforce](-1, -1, 1) {
    if (ev::FlagGet("敵増援左") && !ev::FlagGet("敵増援左2")) {
        ev::Dispos("Reinforce02", 8);
        ev::DisposWait();
        ev::FlagSet("敵増援左2");
    }
    if (ev::FlagGet("敵増援条件左") && !ev::FlagGet("敵増援左")) {
        ev::Dispos("Reinforce01", 8);
        ev::DisposWait();
        ev::FlagSet("敵増援左");
    }
    if (ev::FlagGet("敵増援右") && !ev::FlagGet("敵増援右2")) {
        ev::Dispos("Reinforce04", 8);
        ev::DisposWait();
        ev::FlagSet("敵増援右2");
    }
    if (ev::FlagGet("敵増援条件右") && !ev::FlagGet("敵増援右")) {
        ev::Dispos("Reinforce03", 8);
        ev::DisposWait();
        ev::FlagSet("敵増援右");
    }
    if (!ev::FlagGet("敵増援中央")) {
        v0 = ev::UnitGetByPID("PID_B022_絡繰師中央");
        if (!v0) {
            v1 = 4;
            if (ev::DifficultyGet() >= 2) {
                v1 = 3;
            }
            v2 = ev::VariableGet("敵増援条件中央カウンタ");
            v2++;
            if (v2 >= v1) {
                ev::Dispos("Reinforce05", 8);
                ev::DisposWait();
                ev::FlagSet("敵増援中央");
            }
            ev::VariableSet("敵増援条件中央カウンタ", v2);
        }
    }
    if (ev::FlagGet("敵増援竜脈") && !ev::FlagGet("敵増援竜脈2")) {
        v2 = ev::ForceUnitGetFirst(1);
        while (v2) {
            if (!ev::UnitTstPrivateSkill(v2, "SPID_移動禁止")) {
                ev::AiSetActive(v2, 1);
                ev::AiSetSequence(v2, 3, "AI_MV_WeakEnemy", "");
            }
            v2 = ev::ForceUnitGetNext(v2);
        }
        ev::Dispos("Reinforce10", 8);
        ev::DisposWait();
        ev::Dispos("Reinforce11", 8);
        ev::DisposWait();
        ev::Dispos("Reinforce12", 8);
        ev::DisposWait();
        ev::FlagSet("敵増援竜脈2");
    }
    if (ev::FlagGet("敵増援条件竜脈") && !ev::FlagGet("敵増援竜脈")) {
        ev::Dispos("Reinforce06", 8);
        ev::DisposWait();
        ev::Dispos("Reinforce07", 8);
        ev::DisposWait();
        ev::Dispos("Reinforce08", 8);
        ev::DisposWait();
        ev::Dispos("Reinforce09", 8);
        ev::DisposWait();
        ev::FlagSet("敵増援竜脈");
    }
}

