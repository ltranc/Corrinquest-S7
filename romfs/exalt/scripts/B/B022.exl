callback[Event.MapLoad]() {
    ev::ChapterSetWinRuleBreakdown(1);
    ev::ChapterSetTrickDragon(1);
    ev::PersonLoad(ev::ChapterGetName());
    ev::TerrainLoad(ev::ChapterGetName());
    ev::DisposLoad(ev::ChapterGetName());
    ev::Dispos("Player", 4);
    ev::Dispos("Enemy", 4);
    if (ev::DifficultyGet() <= 0) {
        v0 = ev::UnitGetByPID("PID_B022_ボス");
        if (v0) {
            ev::UnitSetPrivateSkill(v0, "SPID_回避-10");
        }
    }
    v0 = ev::ForceUnitGetFirst(0);
    while (v0) {
        v1 = ev::ForceUnitGetNext(v0);
        ev::UnitSetPrivateSkill(v0, "SPID_ダブル禁止");
        v0 = v1;
    }
    v0 = ev::ForceUnitGetFirst(3);
    while (v0) {
        v1 = ev::ForceUnitGetNext(v0);
        ev::UnitSetPrivateSkill(v0, "SPID_ダブル禁止");
        v0 = v1;
    }
    v2 = ev::UnitGetByPID(SUBAKI);
    ev::UnitItemToTransporter(v2);
    ev::UnitExpulsionByIndex(v2);
    v3 = ev::UnitGetByPID(CAELDORI);
    ev::UnitItemToTransporter(v3);
    ev::UnitExpulsionByIndex(v3);
    v4 = ev::UnitGetByPID("PID_B022_ツバキ");
    if (v4) {
        ev::UnitSetEnhance(v4, 11);
        ev::UnitSetEnhance(v4, 18);
        ev::UnitSetEnhance(v4, 40);
    }
    v5 = ev::UnitGetByPID("PID_B022_ボス");
    if (v5) {
        ev::UnitSetPrivateSkill(v5, "SPID_強制必殺回避");
    }
    v6 = ev::UnitGetByPID("PID_B022_修羅2");
    if (v6) {
        ev::UnitSetMovePower(v6, 2);
    }
    v6 = ev::UnitGetByPID("PID_B022_陰陽師2");
    if (v6) {
        ev::UnitSetMovePower(v6, 2);
    }
    v7 = ev::UnitGetByPID("PID_B022_サクラ");
    if (v7) {
        ev::UnitSetEnhance(v7, 38);
    }
}

callback[Event.MapFree]() {
    v0 = ev::ForceUnitGetFirst(0);
    while (v0) {
        v1 = ev::ForceUnitGetNext(v0);
        ev::UnitClrPrivateSkill(v0, "SPID_ダブル禁止");
        v0 = v1;
    }
    v0 = ev::ForceUnitGetFirst(3);
    while (v0) {
        v1 = ev::ForceUnitGetNext(v0);
        ev::UnitClrPrivateSkill(v0, "SPID_ダブル禁止");
        v0 = v1;
    }
    ev::DisposFree();
    ev::TerrainFree();
    ev::PersonFree(ev::ChapterGetName());
}

callback[Event.MapOpening]() {
    ev::CutScene("B022_OP1");
    ev::CutScene("B022_EV1");
}

callback[Event.MapSetting]() {
    if (ev::DifficultyGet() <= 0) {
        ev::TrickSet(13, 5, 11, 2, 2);
    }
    ev::TrickSet(13, 1, 3, 2, 0);
    ev::TrickSet(25, 6, 0, 4, 0);
    ev::TrickSet(1, 12, 0, 4, 0);
}

callback[Event.Turn](1, 1, 0) {
    ev::TutorialDialogMustShow("MID_B022_DIALOG");
    v0 = ev::ForceUnitGetFirst(0);
    while (v0) {
        v1 = ev::ForceUnitGetNext(v0);
        ev::UnitClrPrivateSkill(v0, "SPID_ダブル禁止");
        v0 = v1;
    }
    v0 = ev::ForceUnitGetFirst(3);
    while (v0) {
        v1 = ev::ForceUnitGetNext(v0);
