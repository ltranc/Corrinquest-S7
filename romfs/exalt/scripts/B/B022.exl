def anonfn18() {
    if (ev::FlagGet("Puppets")) {
        return 0;
    }
    v0 = ev::UnitGetByPID("PID_B022_オロチ");
    if (v0) {
        if (ev::UnitGetX(v0) == 12 && ev::UnitGetY(v0) == 1) {
            return 0;
        }
    }
    v0 = ev::UnitGetByPID("PID_B022_ユウギリ");
    if (v0) {
        if (ev::UnitGetX(v0) == 14 && ev::UnitGetY(v0) == 1) {
            return 0;
        }
    }
    return 1;
}

callback[Event.Reinforce](-1, -1, 1) {
    if (anonfn18()) {
        ev::Dispos("Reinforce13", 8);
        ev::DisposWait();
        ev::FlagSet("Puppets");
        v0 = ev::UnitGetByPID("PID_B022_オロチ");
        v1 = ev::UnitGetByPID("PID_B022_ユウギリ");
        if (!v0 || !v1) {
            v2 = ev::ForceUnitGetFirst(1);
            while (v2) {
                if (ev::AiGetBand(v2) == 3) {
                    ev::AiSetMoveLimit(v2, 0, -1, -1, -1, -1);
                }
                v2 = ev::ForceUnitGetNext(v2);
            }
        }
    }
}

