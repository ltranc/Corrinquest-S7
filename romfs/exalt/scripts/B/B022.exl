        ev::Dispos("Reinforce10", 8);
        ev::DisposWait();
        ev::Dispos("Reinforce11", 8);
        ev::DisposWait();
        ev::Dispos("Reinforce12", 8);
        ev::DisposWait();
        ev::FlagSet("敵増援竜脈2");
