callback[Event.Die]("PID_B025_シノノメ", 1, "", -1) {
    if (!ev::FlagGet("Paired")) {
        v0 = ev::UnitGetByPID("PID_B025_グレイ");
        if (v0) {
            ev::AiSetSequence(v0, 2, "AI_AT_Attack", "");
            ev::AiSetSequence(v0, 3, "AI_MV_WeakEnemy", "");
        }
        v1 = ev::UnitGetByPID("PID_B025_ボス");
        if (v1) {
            ev::AiSetSequence(v1, 3, "AI_MV_WeakEnemy", "");
            ev::AiSetMoveLimit(v1, -1, -1, -1, -1, -1);
        }
    }
}

callback[Event.MapComplete]() {
    v0 = ev::UnitGetPlayer();
    if (v0) {
        ev::UnitClrPrivateSkill(v0, "SPID_ダブル禁止");
        ev::UnitClrPrivateSkill(v0, "SPID_ワープ禁止");
    }
    ev::EnvSEOff(250);
    ev::FadeOut(3, 0, 250);
    ev::FadeWait();
    ev::MapEventBeginForComplete();
    ev::Dispos("Event11", 2052);
    ev::CameraSetPosition(14, 12);
    ev::CameraSetAngle(-40);
    ev::CameraSetDistanceFromNear();
    ev::CameraInstant();
    ev::BGMPlay("STRM_EVT_AMB_A1", 0);
    ev::EnvSEOn(250);
    ev::FadeIn(3, 0, 250);
    ev::FadeWait();
    ev::TimeWait(500);
    ev::Talk("MID_B025_EV_1");
    v1 = ev::UnitGetPlayer();
    ev::UnitMovePosition(v1, 14, 18, 0);
    ev::UnitMoveWait();
    ev::Talk("MID_B025_EV_2");
    ev::BGMStop(1000);
    ev::EnvSEOff(1000);
    ev::FadeOut(3, 0, 1000);
    ev::FadeWait();
    ev::MapEventEndForComplete();
}

