    ev::Talk("MID_B026_BOSS_DIE2");
    if(ev::FlagGet("増援条件4") || ev::FlagGet("増援条件6")) {
        v0 = ev::VariableGet("Move");
        if (v0 < 4) {
            ev::VariableSet("Move", 4);
        }
    }
}

callback[Event.MapComplete]() {
    ev::EnvSEOff(250);
    ev::FadeOut(3, 0, 250);
    ev::FadeWait();
    ev::MapEventBeginForComplete();
    ev::TrickSet(13, 21, 9, 2, 2);
    ev::CameraSetPosition(13, 22);
    ev::CameraSetAngle(-40);
    ev::CameraSetDistanceFromNear();
    ev::CameraInstant();
    ev::Dispos("Event11", 2052);
    ev::BGMPlay("STRM_EVT_ENEMY_E1_2", 50);
    ev::EnvSEOn(250);
    ev::FadeIn(3, 0, 250);
    ev::FadeWait();
    ev::TimeWait(500);
    ev::Talk("MID_B026_ED_1");
    v0 = ev::UnitGetByPID("PID_B026_イベント用マクベス");
    ev::UnitMovePosition(v0, 13, 21, 0);
    ev::UnitMoveWait();
    ev::Talk("MID_B026_ED_2");
    v1 = ev::UnitGetByPID(LEO);
    v2 = [65, 0];
    ev::Battle(v1, 0, v0, 0, &v2[0]);
    ev::Talk("MID_B026_ED_3");
    ev::UnitMoveAlphaDeadOut(v0);
    ev::UnitMoveWait();
    ev::UnitExpulsionByIndex(v0);
    ev::Talk("MID_B026_ED_4");
    ev::BGMStop(2000);
    ev::EnvSEOff(2000);
    ev::FadeOut(3, 0, 2000);
    ev::FadeWait();
    ev::MapEventEndForComplete();
}

