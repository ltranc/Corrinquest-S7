callback[Event.MapComplete]() {
    ev::EnvSEOff(250);
    ev::FadeOut(3, 0, 250);
    ev::FadeWait();
    ev::MapEventBeginForComplete();
    ev::CameraSetPosition(21, 5);
    ev::CameraSetAngle(-40);
    ev::CameraSetDistanceFromNear();
    ev::CameraInstant();
    ev::Dispos("Event11", 2052);
    ev::BGMPlay("STRM_EVT_BRAVE_A1", 0);
    ev::EnvSEOn(250);
    ev::FadeIn(3, 0, 250);
    ev::FadeWait();
    ev::TimeWait(500);
    ev::Talk("MID_B020_ED_1");
    ev::BGMVolume(0, 7000);
    v0 = ev::UnitGetByPID("PID_B020_EDイベント用フウガ");
    v1 = ev::UnitGetByPID("PID_B020_EDイベント用ツクヨミ");
    ev::UnitMovePosition(v0, 10, 5, 0);
    ev::TimeWait(250);
    ev::UnitMovePosition(v1, 11, 5, 0);
    ev::UnitMoveWait();
    ev::Talk("MID_B020_ED_2");
    v2 = ev::UnitGetPlayer();
    v3 = ev::UnitGetByPID(AZURA);
    ev::UnitMovePosition(v2, 12, 5, 0);
    ev::UnitMovePosition(v3, 13, 5, 0);
    ev::UnitMoveWait();
    ev::BGMStop(2000);
    ev::EnvSEOff(2000);
    ev::FadeOut(3, 0, 2000);
    ev::FadeWait();
    ev::MapEventEndForComplete();
}

callback[Event.MapEnding]() {}

