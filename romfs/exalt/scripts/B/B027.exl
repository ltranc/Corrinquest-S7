include std:fe14:prelude;

callback[Event.ScriptLoad]() {
    ev::FlagEntry("戦闘会話");
    ev::FlagEntry("戦闘会話_プレイヤー");
    ev::FlagEntry("移動制限解除");
    ev::FlagEntry("カットシーン");
}

callback[Event.MapLoad]() {
    ev::ChapterSetWinRuleDestroyBoss(1);
    ev::PersonLoad(ev::ChapterGetName());
    ev::TerrainLoad(ev::ChapterGetName());
    ev::DisposLoad(ev::ChapterGetName());
    ev::Dispos("Player", 4);
    ev::Dispos("Enemy2", 4);
    if (ev::DifficultyGet() <= 0) {
        v0 = ev::UnitGetByPID("PID_B027_ボス");
        if (v0) {
            ev::UnitSetPrivateSkill(v0, "SPID_回避-10");
        }
    }
    ev::GiveSkill("PID_B027_PAPERZAC", AGGRESSOR, SPENDTHRIFT, COUNTERMAGIC);
    ev::GiveSkill("PID_B027_LARGO", SEAL_STRENGTH, CERTAIN_BLOW, 0);
    ev::GiveSkill("PID_B027_LLAMA", QUICK_DRAW, ODD_SHAPED, 0);
    v0 = ev::UnitGetByPID("PID_B027_LLAMA");
    if(v0) {
        ev::UnitSetEnhance(v0, 12);
        ev::UnitSetEnhance(v0, 42);
    }
    ev::GiveSkill("PID_B027_LUCIUS", WARDING_BLOW, SEAL_DEFENSE, 0);
    ev::GiveSkill("PID_B027_BANANA", SEAL_STRENGTH, DUELISTS_BLOW, 0);
    ev::GiveSkill("PID_B027_OCTOPUSVIO", REND_HEAVEN, QUIXOTIC, SPENDTHRIFT);
    ev::GiveSkill("PID_B027_ANNA", SPENDTHRIFT, CERTAIN_BLOW, WARY_FIGHTER);
    ev::GiveSkill("PID_B027_2B", SEAL_DEFENSE, SEAL_SPEED, 0);
    ev::GiveSkill("PID_B027_LOTTE", GOOD_FORTUNE, DARTING_BLOW, SPENDTHRIFT);
    ev::GiveSkill("PID_B027_DENJI", SEAL_SPEED, ARMORED_BLOW, 0);
    ev::GiveSkill("PID_B027_FON", SEAL_SPEED, ARMORED_BLOW, 0);
    ev::GiveSkill("PID_B027_SILVER", HEARTSEEKER, VANTAGE, 0);
    ev::GiveSkill("PID_B027_DITO", WARDING_BLOW, SEAL_DEFENSE, 0);
    ev::GiveSkill("PID_B027_LTRANCMADEME", POISON_STRIKE, GRISLY_WOUND, 0);
    ev::GiveSkill("PID_B027_CEDAROIL", STRONG_RIPOSTE, DANCING_BLADE, COUNTERMAGIC);
    ev::GiveSkill("PID_B027_FORSYTH", LIFE_AND_DEATH, VANTAGE, SPENDTHRIFT);
    ev::GiveSkill("PID_B027_CHEW", SEAL_SPEED, ARMORED_BLOW, 0);
    ev::GiveSkill("PID_B027_LUCKZO", LUCKTAKER_SKILL, PROFITEER, SPENDTHRIFT);
    v0 = ev::UnitGetByPID("PID_B027_LUCKZO");
    if(v0) {
        #Lck tonic
        ev::UnitSetEnhance(v0, 13);
    }
    ev::GiveSkill("PID_B027_KOHAKU", SEAL_SPEED, ARMORED_BLOW, 0);
    v0 = ev::UnitGetByPID("PID_B027_KOHAKU");
    if(v0) {
        #Skl and Lck tonics
        ev::UnitSetEnhance(v0, 11);
        ev::UnitSetEnhance(v0, 13);
    }
    ev::GiveSkill("PID_B027_AUDIEJ", POISON_STRIKE, LETHALITY, 0);
    v0 = ev::UnitGetByPID("PID_B027_AUDIEJ");
    if(v0) {
        #Cannot activate proc skills
        ev::UnitSetPrivateSkill(v0, "SPID_スキル発動禁止");
    }
    ev::GiveSkill("PID_B027_JASPER", COUNTER, SPENDTHRIFT, COUNTERMAGIC);
    ev::GiveSkill("PID_B027_BORP", PAVISE, DARTING_BLOW, SPENDTHRIFT);
    ev::GiveSkill("PID_B027_YOUTA", LIFE_AND_DEATH, SPENDTHRIFT, COUNTERMAGIC);
    ev::GiveSkill("PID_B027_SNOWY", VENGEANCE, VANTAGE, 0);
    ev::GiveSkill("PID_B027_NOCKING", QUICK_DRAW, ODD_SHAPED, 0);
}

callback[Event.MapFree]() {
    ev::DisposFree();
    ev::TerrainFree();
    ev::PersonFree(ev::ChapterGetName());
}

def ev::B027_夜刀神・暗夜入手(v0) {
    if (ev::ItemReplaceForYatonokami(GRIM_YATO, SHADOW_YATO)) {
        if (ev::CutSceneGameEventBegin(v0, "カットシーン")) {
            ev::BGMPlay("STRM_EVT_UNITE_C1", 0);
            ev::ItemGainMessageOnlyNoSound(SHADOW_YATO);
        }
        ev::CutSceneGameEventEnd(v0);
    }
}

callback[Event.MapOpening]() {
    ev::CutScene("B027_OP1");
    ev::MoviePlayWithEscapeSkip("s15");
    ev::CutScene("B027_OP2");
    ev::CutScene("B027_OP3");
    ev::CutScene("B027_OP4");
    ev::B027_夜刀神・暗夜入手(0);
    ev::MapEventBeginForOpening(0);
    ev::CameraSetPosition(15, 8);
    ev::CameraSetAngle(-40);
    ev::CameraSetDistanceFromNear();
    ev::CameraInstant();
    ev::Dispos("Event01", 2052);
    ev::EnvSEOn(250);
    ev::FadeIn(3, 0, 250);
    ev::FadeWait();
    ev::TimeWait(500);
    ev::Talk("MID_B027_OP5_1");
    v0 = ev::UnitGetPlayer();
    v1 = ev::UnitGetByPID("PID_B027_OPイベント用溶解ガロン");
    v2 = [33, 65, 0];
    ev::Battle(v0, 0, v1, 0, &v2[0]);
    ev::Talk("MID_B027_OP5_2");
    ev::EnvSEOff(250);
    ev::FadeOut(3, 0, 250);
    ev::FadeWait();
    ev::MapEventEndForOpening();
}

callback[Event.Turn](1, 1, 0) {
    ev::SkipDisable();
    anonfn28(3, 11, 3, 12);
    anonfn28(27, 11, 27, 12);
    v0 = ev::UnitGetByPosition(4, 12);
    if (v0) {
        ev::CameraSetPositionByUnit(v0);
        ev::CameraWait();
        ev::TimeWait(150);
        ev::UnitMovePosition(v0, 3, 12, 0);
        ev::TimeWait(50);
    }
    v1 = ev::UnitGetByPosition(26, 12);
    if (v1) {
        ev::CameraSetPositionByUnit(v1);
        ev::CameraWait();
        ev::TimeWait(150);
        ev::UnitMovePosition(v1, 27, 12, 0);
        ev::TimeWait(50);
    }
    ev::SkipEnable();
}

callback[Event.Turn](-1, -1, 1) {
    v0 = 0;
    v1 = ev::ForceUnitGetFirst(1);
    while (v1) {
        if (ev::UnitIsPID(v1, "PID_B027_巫女")) {
            if (ev::UnitItemIsExist(v1, ENTRAP_B027)) {
                v0++;
                goto l1;
            }
            ev::AiSetPriority(v1, 0);
        }
        label l1;
        v1 = ev::ForceUnitGetNext(v1);
    }
    for (v2 = 0; v2 < v0; v2++) {
        v3 = ev::RandomGetSystem();
        v4 = v3 % (v0 - v2);
        v5 = ev::ForceUnitGetFirst(1);
        while (v5) {
            if (ev::UnitIsPID(v5, "PID_B027_巫女")) {
                if (ev::AiGetPriority(v5) == 0) {
                    if (ev::UnitItemIsExist(v5, ENTRAP_B027)) {
                        if (v4 <= 0) {
                            ev::AiSetPriority(v5, 101 + v2);
                            break;
                        }
                        v4--;
                    }
                }
            }
            v5 = ev::ForceUnitGetNext(v5);
        }
    }
    if (ev::DifficultyGet() >= 2) {
        if (!ev::FlagGet("移動制限解除")) {
            v6 = ev::ForceUnitGetCountArea(0, 12, 1, 18, 30, 1);
            if (v6 <= 0) {
                v7 = ev::ForceUnitGetFirst(1);
                while (v7) {
                    if (ev::AiGetBand(v7) == 1) {
                        ev::AiSetMoveLimit(v7, 0, -1, -1, -1, -1);
                    }
                    v7 = ev::ForceUnitGetNext(v7);
                }
                ev::FlagSet("移動制限解除");
            }
        }
    }
}

callback[Event.TurnAfter](1, 1, 1) {
    ev::SkipDisable();
    anonfn28(2, 16, 2, 17);
    anonfn28(1, 22, 1, 23);
    if(ev::UnitGetByPID("PID_B027_AUDIEJ")) {
        ev::TutorialDialogMustShow("MID_B027_DIALOG");
    }
    anonfn28(28, 16, 28, 17);
    anonfn28(29, 22, 29, 23);
    ev::SkipEnable();
}

callback[Event.Turn](6, 6, 0) {
    v0 = ev::UnitGetByPID("PID_B027_AUDIEJ");
    if(v0) {
        ev::UnitClrPrivateSkill(v0, "SPID_スキル発動禁止");
    }
}

def anonfn8(v0, v1, v2, v3, v4) {
    if (!ev::TrickTst(v0, v1, 9, 1)) {
        return 0;
    }
    if ((ev::UnitGetByPID(v2) || ev::UnitGetByPID(v3)) || ev::UnitGetByPID(v4)) {
        return 0;
    }
    return 1;
}

def anonfn9(v0, v1) {
    ev::CameraSetPosition(v0, v1);
    ev::CameraWait();
    ev::TrickSet(v0, v1, 9, 2, 0);
}

