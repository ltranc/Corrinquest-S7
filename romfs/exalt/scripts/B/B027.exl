def ev::GiveSkill(v0, v1, v2, v3) {
    v0 = ev::UnitGetByPID(v0);
    if (v0) {
        ev::UnitAddEquipSkill(v0, v1);
        if (v2 != 0) {
            ev::UnitAddEquipSkill(v0, v2);
        }
        if (v3 != 0) {
            ev::UnitAddEquipSkill(v0, v3);
        }
        if (ev::UnitIsEquipSkill(v0, FOREIGN_PRINCESS)) {
            ev::UnitSetEnhance(v0, 9);
            ev::UnitSetEnhance(v0, 10);
            ev::UnitSetEnhance(v0, 14);
            ev::UnitSetEnhance(v0, 15);
        }
        if (ev::UnitIsEquipSkill(v0, HP_PLUS_5)) {
            ev::UnitSetHP(v0, ev::UnitGetMHP(v0));
        }
    }
}

#Pairs up units
def anonfn23(v0, v1) {
    v0 = ev::UnitGetByPID(v0);
    v1 = ev::UnitGetByPID(v1);
    if (v0 && v1) {
        v2 = ev::UnitGetX(v0);
        v3 = ev::UnitGetY(v0);
        v4 = ev::UnitGetX(v1);
        v5 = ev::UnitGetY(v1);
        v6 = 0;
        if (v2 > v4) {
            v6 = v2 - v4;
            goto l3;
        }
        v6 = v4 - v2;
        label l3;
        if (v3 > v5) {
            v6 = (v6 + v3) - v5;
            goto l5;
        }
        v6 = (v6 + v5) - v3;
        label l5;
        if (v6 <= 7) {
            ev::CameraSetPositionByUnit(v0);
            ev::CameraWait();
            ev::TimeWait(250);
            if (v6 > 1) {
                ev::UnitMovePosition(v1, v2, v3 - 1, 0);
                ev::TimeWait(v6 * 50);
            }
            ev::UnitDoubleOn(v0, v1);
            ev::TimeWait(250);
        }
    }
}

def ev::ShadowgiftEffect(v0) {
    v0 = ev::UnitGetByPID(v0);
    if (v0) {
        ev::UnitClrEnhance(v0, 7);
        ev::UnitClrEnhance(v0, 6);
        ev::UnitClrEnhance(v0, 5);
        v1 = ev::UnitGetWeakness(v0, 2);
        if (v1 > 1) {
            v1 = v1 * -1;
            ev::UnitAddWeakness(v0, 2, v1);
        }
        v1 = ev::UnitGetWeakness(v0, 1);
        if (v1 > 1) {
            v1 = v1 * -1;
            ev::UnitAddWeakness(v0, 1, v1);
        }
    }
}

def ev::FortifySpectrumEffect(v0) {
    v0 = ev::UnitGetByPID(v0);
    if (v0) {
        v1 = ev::UnitGetX(v0);
        v2 = ev::UnitGetY(v0);
        v3 = ev::ForceUnitGetFirst(1);
        while (v3) {
            v4 = ev::UnitGetX(v3);
            v5 = ev::UnitGetY(v3);
            if (v1 - v4 == 1 || v4 - v1 == 1) {
                if (v2 == v5) {
                    ev::UnitSetEnhance(v3, 31);
                }
            }
            if (v5 - v2 == 1 || v2 - v5 == 1) {
                if (v1 == v4) {
                    ev::UnitSetEnhance(v3, 31);
                }
            }
            v6 = ev::ForceUnitGetNext(v3);
            v3 = v6;
        }
    }
}

def ev::ResolveEffect(v0) {
    v0 = ev::UnitGetByPID(v0);
    if (v0) {
        if (ev::UnitGetHP(v0) * 2 <= ev::UnitGetMHP(v0)) {
            ev::UnitSetEnhance(v0, 16);
            ev::UnitSetEnhance(v0, 17);
            ev::UnitSetEnhance(v0, 18);
            ev::UnitSetEnhance(v0, 19);
            goto l0;
        }
        ev::UnitClrEnhance(v0, 16);
        ev::UnitClrEnhance(v0, 17);
        ev::UnitClrEnhance(v0, 18);
        ev::UnitClrEnhance(v0, 19);
    }
    label l0;
}

def ev::WitchsBrewEffect(v0) {
    v0 = ev::UnitGetByPID(v0);
    if (v0) {
        v1 = ev::RandomGetGame() % 100;
        v2 = ev::UnitGetCapability(v0, 5, 1);
        v2 = v2 * 2;
        if (ev::UnitIsEquipSkill(v0, HOSHIDAN_UNITY)) {
            v2 = v2 + 10;
        }
        if (v1 < v2) {
            v3 = ev::RandomGetGame() % 8;
            match (v3) {
                #HP
                0 -> {
                    if (!ev::UnitTstEnhance(v0, 8)) {
                        ev::UnitSetEnhance(v0, 8);
                        ev::UnitSetHP(v0, ev::UnitGetHP(v0) + 5);
                        if (ev::UnitIsEquipSkill(v0, POTENT_POTION)) {
                            ev::UnitSetHP(v0, ev::UnitGetHP(v0) + 2);
                        }
                    }
                }
                #Str
                1 -> {
                    if (!ev::UnitTstEnhance(v0, 9)) {
                        ev::UnitSetEnhance(v0, 9);
                    }
                }
                #Mag
                2 -> {
                    if (!ev::UnitTstEnhance(v0, 10)) {
                        ev::UnitSetEnhance(v0, 10);
                    }
                }
                #Skl
                3 -> {
                    if (!ev::UnitTstEnhance(v0, 11)) {
                        ev::UnitSetEnhance(v0, 11);
                    }
                }
                #Spd
                4 -> {
                    if (!ev::UnitTstEnhance(v0, 12)) {
                        ev::UnitSetEnhance(v0, 12);
                    }
                }
                #Lck
                5 -> {
                    if (!ev::UnitTstEnhance(v0, 13)) {
                        ev::UnitSetEnhance(v0, 13);
                    }
                }
                #Def
                6 -> {
                    if (!ev::UnitTstEnhance(v0, 14)) {
                        ev::UnitSetEnhance(v0, 14);
                    }
                }
                #Res
                7 -> {
                    if (!ev::UnitTstEnhance(v0, 15)) {
                        ev::UnitSetEnhance(v0, 15);
                    }
                }
            }
        }
    }
}

#Pairs up units
def anonfn28(v0, v1, v2, v3) {
    v4 = ev::UnitGetByPosition(v0, v1);
    v5 = ev::UnitGetByPosition(v2, v3);
    if (v4 && v5) {
        ev::CameraSetPositionByUnit(v4);
        ev::CameraWait();
        ev::TimeWait(250);
        ev::UnitDoubleOn(v4, v5);
        ev::TimeWait(250);
    }
}

def ev::ProfiteerEffect(v0) {
    v0 = ev::UnitGetByPID(v0);
    if (v0) {
        v1 = ev::RandomGetGame() % 100;
        v2 = ev::UnitGetCapability(v0, 5, 1);
        v2 = v2 * 3;
        v2 = v2 / 2;
        if (ev::UnitIsEquipSkill(v0, HOSHIDAN_UNITY)) {
            v2 = v2 + 10;
        }
        if (v1 < v2) {
            ev::ItemGainSilent(v0, GOLD_BAR);
        }
    }
}

