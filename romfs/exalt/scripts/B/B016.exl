include std:fe14:prelude;

def ev::LocalTutorial0() {
    return "MID_B016_DIALOG1";
}

callback[Event.ScriptLoad]() {
    ev::FlagEntry("戦闘会話");
    ev::FlagEntry("会話_容疑者1");
    ev::FlagEntry("会話_容疑者2");
    ev::FlagEntry("会話_容疑者3");
    ev::FlagEntry("会話_容疑者4");
    ev::FlagEntry("会話使用済1");
    ev::FlagEntry("会話使用済2");
    ev::FlagEntry("会話使用済3");
    ev::FlagEntry("カットシーン");
    ev::FlagEntry("カットシーン2");
    ev::FlagEntry("ターン資金強奪");
    ev::VariableEntry("マクベス軍資金", 10000);
    ev::VariableEntry("Spy", 0);
    ev::VariableEntry("Spy2", 0);
}

callback[Event.MapLoad]() {
    ev::PersonLoad("B_HANDOVER");
    ev::PersonLoad(ev::ChapterGetName());
    ev::TerrainLoad(ev::ChapterGetName());
    ev::DisposLoad(ev::ChapterGetName());
    ev::Dispos("Player", 4);
    ev::Dispos("Enemy", 4);
    ev::Dispos("Ally", 4);
    ev::ForceUnitSetDontAttackForce(1, 2);
}

callback[Event.MapFree]() {
    ev::DisposFree();
    ev::TerrainFree();
    ev::PersonFree(ev::ChapterGetName());
    ev::PersonFree("B_HANDOVER");
}

callback[Event.MapOpening]() {
    ev::CutScene("B016_OP1_1");
    ev::CutScene("B016_OP1_2");
    ev::CutScene("B016_OP2_1");
    v0 = ev::UnitGetByPID(PERI);
    if (v0 && ev::UnitIsAlive(v0)) {
        ev::CutScene("B016_OP2_2");
        goto l2;
    }
    ev::CutScene("B016_OP2_2B");
    label l2;
    ev::CutScene("B016_OP3");
}

callback[Event.Turn](1, 1, 0) {
    ev::CameraSetAngle(-40);
    ev::CameraSetDistanceFromNear();
    ev::Talk("MID_B016_EV1");
    ev::CameraSetAngleFromConfig();
    ev::CameraSetDistanceFromConfig();
    ev::TimeWait(500);
    ev::SkipEscape();
    ev::TutorialDialogMustShow("MID_B016_DIALOG1");
    ev::VariableSet("Spy", ev::RandomGetGame() % 3);
    if(ev::VariableGet("Spy") == 1) {
        ev::VariableSet("Spy2", 0);
    } else {
        ev::VariableSet("Spy2", 2 - ev::VariableGet("Spy"));
    }
}

callback[Event.Reinforce](-1, -1, 1) {
    v0 = ev::UnitGetByPID("PID_B016_ボス");
    if (v0) {
        v1 = ev::ForceUnitGetFirst(1);
        while (v1) {
            if (ev::UnitTstPrivateSkill(v1, "SPID_移動禁止")) {
                ev::UnitClrPrivateSkill(v1, "SPID_移動禁止");
            }
            v1 = ev::ForceUnitGetNext(v1);
        }
    }
}

def anonfn7() {
    if (ev::FlagGet("ターン資金強奪")) {
        return 0;
    }
    v0 = ev::VariableGet("マクベス軍資金");
    if (v0 > 0) {
        v1 = 300;
        if (v0 > v1) {
            v0 -= v1;
            goto l3;
        }
        v1 = v0;
        v0 = 0;
        label l3;
        ev::VariableSet("マクベス軍資金", v0);
        ev::MessSetArgumentByValue(0, v1);
        ev::MessSetArgumentByValue(1, v0);
        ev::TutorialDialogMustShow("MID_B016_DIALOG2");
        if (v0 <= 0) {
            ev::Talk("MID_B016_EV8");
        }
    }
    ev::FlagSet("ターン資金強奪");
}

callback[Event.TurnAfter](1, -1, 0) {
    ev::FlagClr("ターン資金強奪");
}

callback[Event.TurnAfter](1, -1, 1) {
    anonfn7();
}

callback[Event.TurnAfter](1, -1, 2) {
    anonfn7();
}

