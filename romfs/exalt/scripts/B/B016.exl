callback[Event.BattleTalk]("PID_B016_ボス", 1, "", -1, 1, "戦闘会話") {
    ev::Talk("MID_B016_BT1");
    ev::FlagSet("戦闘会話");
}

callback[Event.Die]("PID_B016_ボス", 1, "", -1) {
    ev::Talk("MID_B016_BOSS_DIE1");
}

callback[Event.MapComplete]() {
    v0 = ev::VariableGet("マクベス軍資金");
    if (v0 > 0) {
        ev::GoldGain(0, v0);
    }
}

def ev::B016_アシュラを殺す？(v0) {
    if (ev::CutSceneGameEventBegin(v0, "カットシーン")) {
        if (!v0) {
            ev::SkipDisable();
        }
        ev::DialogYesNo("MID_B016_ED1_YN");
        if (!v0) {
            ev::SkipEnable();
        }
        ev::CutSceneGameEventEnd(v0);
    }
}

def ev::B016_ブーツ入手(v0) {
    if (ev::CutSceneGameEventBegin(v0, "カットシーン2")) {
        ev::ItemGain(0, BOOTS);
        ev::CutSceneGameEventEnd(v0);
    }
}

callback[Event.MapEnding]() {
    ev::CutScene("B016_ED1");
    ev::B016_アシュラを殺す？(0);
    if (ev::DialogGetResult() == 0) {
        ev::CutScene("B016_ED2");
        ev::B016_ブーツ入手(0);
        goto l1;
    }
    ev::BGMStop(2000);
    ev::CutScene("B016_ED3");
    ev::PersonLoad("B_HANDOVER");
    ev::PersonLoad(ev::ChapterGetName());
    ev::DisposLoad(ev::ChapterGetName());
    ev::Dispos("Support01", 4);
    ev::DisposFree();
    ev::PersonFree(ev::ChapterGetName());
    ev::PersonFree("B_HANDOVER");
    label l1;
}

