include std:fe14:prelude;

def anonfn0() {
    ev::VariableEntry("風Handle", 0);
    ev::VariableEntry("風状態", 0);
    ev::VariableEntry("風エフェクト状態", -1);
    ev::VariableEntry("風変化継続", 0);
    ev::VariableEntry("風通常継続", 0);
    ev::VariableEntry("HexRemove", 0);
}

def anonfn1() {
    v0 = ev::VariableGet("風状態");
    v1 = ev::VariableGet("風エフェクト状態");
    if (v1 != v0) {
        v2 = ev::VariableGet("風Handle");
        if (v2) {
            ev::EffectFadeOut(v2, 1000);
        }
        match (v0) {
            1 -> {
                v2 = ev::EffectPlayEternal3D("Fld_B024_Sakura2_Loop", 0, 0);
            }
            2 -> {
                v2 = ev::EffectPlayEternal3D("Fld_B024_Sakura0_Loop", 0, 0);
            }
            else -> {
                v2 = ev::EffectPlayEternal3D("Fld_B024_Sakura1_Loop", 0, 0);
            }
        }
        ev::VariableSet("風Handle", v2);
        ev::VariableSet("風エフェクト状態", v0);
    }
}

def anonfn2() {
    v0 = ev::VariableGet("風エフェクト状態");
    v1 = ev::VariableGet("風Handle");
    match (v0) {
        1 -> {
            v1 = ev::EffectPlayEternal3D("Fld_B024_Sakura2_Loop", 0, 0);
        }
        2 -> {
            v1 = ev::EffectPlayEternal3D("Fld_B024_Sakura0_Loop", 0, 0);
        }
        else -> {
            v1 = ev::EffectPlayEternal3D("Fld_B024_Sakura1_Loop", 0, 0);
        }
    }
    ev::VariableSet("風Handle", v1);
}

def anonfn3(v0, v1) {
    v2 = ev::ForceUnitGetFirst(v1);
    while (v2) {
        v3 = ev::ForceUnitGetNext(v2);
        match (v0) {
            1 -> {
                ev::UnitSetEnhance(v2, 50);
                ev::UnitClrEnhance(v2, 51);
            }
            2 -> {
                ev::UnitClrEnhance(v2, 50);
                ev::UnitSetEnhance(v2, 51);
            }
            else -> {
                ev::UnitClrEnhance(v2, 50);
                ev::UnitClrEnhance(v2, 51);
            }
        }
        v2 = v3;
    }
}

def anonfn4() {
    v0 = ev::VariableGet("風状態");
    for (v1 = 0; v1 < 3; v1++) {
        anonfn3(v0, v1);
    }
    anonfn3(v0, 4);
    ev::MapImageUpdate();
}

def anonfn5(v0) {
    ev::VariableSet("風状態", v0);
    anonfn4();
    anonfn1();
}

callback[Event.ScriptLoad]() {
    ev::FlagEntry("戦闘会話");
