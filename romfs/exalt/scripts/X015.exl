callback[Event.MapOpening]() {
    ev::CutScene("X015_OP1");
    ev::MapEventBeginForOpening(1);
    ev::Dispos("Event01", 4);
    ev::CameraSetPosition(13, 28);
    ev::CameraSetAngle(-40);
    ev::CameraSetDistanceFromNear();
    ev::CameraInstant();
    ev::EnvSEOn(250);
    ev::FadeIn(3, 0, 250);
    ev::FadeWait();
    ev::TimeWait(2000);
    ev::Dispos("Event02", 4096);
    v0 = ev::UnitGetByPID(SIEGBERT);
    ev::UnitTransferByIndex(v0, 0);
    ev::DisposWait();
    ev::Talk("MID_X015_OP1_2_1");
    ev::Dispos("Event03", 4096);
    ev::DisposWait();
    ev::Talk("MID_X015_OP1_2_2");
    ev::UnitMovePosition(v0, 15, 26, 0);
    ev::UnitMoveWait();
    v1 = ev::UnitGetByPID("PID_X015_OPイベント用敵1");
    v2 = [577, 0];
    ev::Battle(v0, 0, v1, 0, &v2[0]);
    ev::UnitExpulsionByIndex(v1);
    ev::TimeWait(1000);
    v4 = ev::UnitGetByPID("PID_X015_OPイベント用敵2");
    v5 = [577, 0];
    ev::Battle(v0, 0, v4, 0, &v5[0]);
    ev::UnitExpulsionByIndex(v4);
    ev::Talk("MID_X015_OP1_2_3");
    ev::UnitMovePosition(v0, 14, 15, 0);
    ev::UnitMoveWait();
    ev::Talk("MID_X015_OP1_2_4");
    v7 = ev::UnitGetByPID(XANDER);
    ev::UnitMovePosition(v7, 14, 16, 0);
    ev::UnitMoveWait();
    ev::BGMStop(1000);
    ev::EnvSEOff(1000);
    ev::FadeOut(3, 0, 1000);
    ev::FadeWait();
    ev::MapEventEndForOpening();
    ev::UnitExpulsionByIndex(v0);
}

callback[Event.Turn](1, 1, 0) {
    ev::CameraSetAngle(-40);
    ev::CameraSetDistanceFromNear();
    ev::Talk("MID_X015_OP2");
    ev::CameraSetAngleFromConfig();
    ev::CameraSetDistanceFromConfig();
    ev::TimeWait(500);
    ev::TutorialDialogMustShow("MID_X015_DIALOG");
}

callback[Event.TurnAfter](-1, -1, 1) {
    v0 = ev::UnitGetByPID("PID_X015_CYAN7");
    if (v0 && !ev::FlagGet("CyanPair")) {
        v1 = ev::ForceUnitGetFirst(1);
        while (v1) {
            if (ev::UnitIsClone(v1)) {
                break;
            }
            v1 = ev::ForceUnitGetNext(v1);
        }
        ev::CameraSetPositionByUnit(v0);
        ev::CameraWait();
        ev::TimeWait(250);
        ev::UnitDoubleOn(v0, v1);
        ev::TimeWait(250);
        ev::FlagSet("CyanPair");
    }
    v0 = ev::UnitGetByPID("PID_X015_AEGON");
    v1 = ev::UnitGetByPID("PID_X015_ROBIN");
    if(v0 && v1 && !ev::FlagGet("AegonRobinPair")) {
        ev::CameraSetPositionByUnit(v1);
        ev::CameraWait();
        ev::TimeWait(250);
        ev::UnitMovePosition(v1, ev::UnitGetX(v0), ev::UnitGetY(v0) - 1, 0);
        ev::TimeWait(200);
        ev::UnitDoubleOn(v0, v1);
        ev::TimeWait(250);
        ev::FlagSet("AegonRobinPair");
    }
}

def anonfn6(v0, v1) {
    v2 = [
        "Reinforce01_1", "Reinforce02_1", "Reinforce03_1", "Reinforce04_1", 
        "Reinforce05_1", "Reinforce06_1", "Reinforce07_1", 
    ];
    v9 = [
        "Reinforce01_2", "Reinforce02_2", "Reinforce03_2", "Reinforce04_2", 
        "Reinforce05_2", "Reinforce06_2", "Reinforce07_2", 
    ];
    v16 = [
        18, 27, 4, 21, 
        23, 21, 9, 16, 
        23, 12, 16, 10, 
        21, 8, 
    ];
    v30 = v16[2 * v0];
    v31 = v16[2 * v0 + 1];
    if (ev::TrickTst(v30, v31, 11, 2)) {
        return 0;
    }
    if (v1 == 1) {
        ev::Dispos(v2[v0], 8);
        goto l2;
    }
    ev::Dispos(v9[v0], 8);
    label l2;
    ev::DisposWait();
    return 1;
}

callback[Event.Reinforce](-1, -1, 1) {
    v0 = 2;
    v1 = ev::VariableGet("敵生成数");
    if (v1 >= 12) {
        v0 = 1;
    }
    v2 = 1;
    if (ev::DifficultyGet() >= 2 && v1 < 20) {
        v2 = 2;
    }
    v3 = -1;
    for (v4 = 0; v4 < v2; v4++) {
        v5 = ev::VariableGet("敵生成番号");
        v6 = v5;
        while (1) {
            v7 = v5;
            v5++;
            if (v5 == 7) {
                v5 = 0;
            }
            if (v5 == v3) {
                break;
            }
            if (anonfn6(v7, v0)) {
                ev::VariableAdd("敵生成数", v0);
                v3 = v7;
                break;
            }
            if (v6 == v5) {
                break;
            }
        }
        ev::VariableSet("敵生成番号", v5);
    }
}

