def ev::CyanFight() {
    if (ev::FlagGet("CyanProc")) {
        return 0;
    }
    if (ev::FlagGet("FightCyan3")) {
        return 1;
    }
    return 0;
}

callback[Event.Area](-1, -1, -1, -1, -1, "CyanFight") {
    v0 = ev::UnitGetByPID("PID_X015_CYAN3");
    if (v0) {
        ev::UnitClrPrivateSkill(v0, "SPID_強制スキル発動");
    }
    ev::FlagSet("CyanProc");
}

callback[Event.BattleTalk]("PID_X015_CYAN3", 1, "", -1, 1, "FightCyan3") {
    ev::FlagSet("FightCyan3");
}

callback[Event.Die](SIEGBERT, -1, "", -1) {
    ev::Talk("MID_X015_DIE_ジークベルト");
}

callback[Event.MapComplete]() {
    ev::ItemGain(0, IRON_SWORD);
    ev::ItemGain(0, IRON_LANCE);
    ev::ItemGain(0, JAVELIN);
    ev::ItemGain(0, CONCOCTION);
}

callback[Event.MapEnding]() {
    ev::CutScene("X015_ED1");
}

