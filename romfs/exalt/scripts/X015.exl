    v3 = ev::UnitGetY(v1);
    if (v1) {
        if (!ev::UnitTstStatus(v1, 1, 0)) {
            v4 = ev::ForceUnitGetFirst(1);
            while (v4) {
                if (!ev::UnitIsPID(v4, v0)) {
                    v5 = ev::UnitGetX(v4);
                    v6 = ev::UnitGetY(v4);
                    v7 = v2 - v5;
                    if (v7 < 0) {
                        v7 = v7 * -1;
                    }
                    v8 = v3 - v6;
                    if (v8 < 0) {
                        v8 = v8 * -1;
